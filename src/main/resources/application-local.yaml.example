spring:
  datasource:
    url: jdbc:mysql://localhost:3306/your_db
    username: your_db_user
    password: your_db_password

  # ── OAuth2 소셜 로그인 설정 ─────────────────────────────────────────────
  security:
    oauth2:
      client:
        registration:

          # Google
          google:
            client-id: YOUR_GOOGLE_CLIENT_ID
            client-secret: YOUR_GOOGLE_CLIENT_SECRET
            scope:
              - profile
              - email

          # Kakao
          # 카카오는 Spring Security 기본 provider가 없으므로 provider 블록도 함께 설정
          kakao:
            client-id: YOUR_KAKAO_REST_API_KEY
            client-secret: YOUR_KAKAO_CLIENT_SECRET   # 카카오 앱 설정에서 Client Secret 발급 (없으면 생략 가능)
            client-authentication-method: client_secret_post
            authorization-grant-type: authorization_code
            redirect-uri: "{baseUrl}/login/oauth2/code/kakao"
            scope:
              - profile_nickname
            client-name: Kakao

          # Naver
          naver:
            client-id: YOUR_NAVER_CLIENT_ID
            client-secret: YOUR_NAVER_CLIENT_SECRET
            client-authentication-method: client_secret_post
            authorization-grant-type: authorization_code
            redirect-uri: "{baseUrl}/login/oauth2/code/naver"
            scope:
              - name
              - email
            client-name: Naver

        provider:
          # 카카오 Provider 수동 등록
          kakao:
            authorization-uri: https://kauth.kakao.com/oauth/authorize
            token-uri: https://kauth.kakao.com/oauth/token
            user-info-uri: https://kapi.kakao.com/v2/user/me
            user-name-attribute: id

          # 네이버 Provider 수동 등록
          naver:
            authorization-uri: https://nid.naver.com/oauth2.0/authorize
            token-uri: https://nid.naver.com/oauth2.0/token
            user-info-uri: https://openapi.naver.com/v1/nid/me
            user-name-attribute: response   # 네이버 응답의 최상위 키

# JWT 설정 (기존 유지)
jwt:
  secret: YOUR_JWT_SECRET_BASE64
  expiration: 86400000   # 24시간 (밀리초)

# OpenAI 설정 (기존 유지)
openai:
  api-key: YOUR_OPENAI_API_KEY
  model: gpt-4o-mini

# ── OAuth 리다이렉트 URL 설정 ───────────────────────────────────────────
oauth:
  client-redirect-url: http://localhost:5173/oauth/success   # 로그인 성공 시 프론트 URL
  client-failure-url: http://localhost:5173/oauth/failure    # 로그인 실패 시 프론트 URL

# CORS 설정 (기존 유지)
cors:
  allowed-origins: http://localhost:5173
